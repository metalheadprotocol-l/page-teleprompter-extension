{
  "manifest_version": 3,
  "name": "Page Teleprompter",
  "version": "1.1.0",
  "description": "Turns the text of the current webpage (or your selection) into a floating, auto-scrolling teleprompter overlay.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Page Teleprompter"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ]
}
